# Banco de dados MySQL — preencha com os dados do banco da empresa
DATABASE_URL="mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO"

# API
API_PORT=3000
NODE_ENV=production

# Oracle NBS — preencha com as credenciais do DMS NBS
NBS_DATABASE_HOST=HOST_ORACLE
NBS_DATABASE_PORT=1521
NBS_DATABASE_USER=USUARIO_ORACLE
NBS_DATABASE_PASS=SENHA_ORACLE
NBS_DATABASE_SID=SID_ORACLE